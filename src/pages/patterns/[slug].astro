---
import { getPatterns, entrySlug, roadmapTopicHref } from '@/lib/content';
import RouteRedirect from '@/components/RouteRedirect.astro';

export async function getStaticPaths() {
  const patterns = await getPatterns();
  return patterns.map((entry) => ({
    params: { slug: entrySlug(entry.id) },
    props: {
      title: entry.data.title,
      target: roadmapTopicHref(entrySlug(entry.id))
    }
  }));
}

const { title, target } = Astro.props;
---

<RouteRedirect
  title={`${title} | PatternZ`}
  target={target}
  message="Pattern details now open in the roadmap workspace side panel."
/>