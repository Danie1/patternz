---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import ContentPageLayout from '@/layouts/ContentPageLayout.astro';
import SectionNav from '@/components/SectionNav.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import QuickSummary from '@/components/QuickSummary.astro';
import DiagramBlock from '@/components/DiagramBlock.astro';
import TrackView from '@/components/TrackView.astro';
import { entrySlug, extractFirstMermaidBlock, linkifyConcepts } from '@/lib/content';

export async function getStaticPaths() {
  const patterns = await getCollection('patterns');
  return patterns.map((entry) => ({
    params: { slug: entrySlug(entry.id) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const allPatterns = await getCollection('patterns');
const allScenarios = await getCollection('scenarios');
const allConcepts = await getCollection('concepts');

const relatedPatternLinks = allPatterns
  .filter((item) => entry.data.related_patterns.includes(item.data.id))
  .map((item) => ({ label: item.data.title, href: `/patterns/${entrySlug(item.id)}` }));

const relatedScenarioLinks = allScenarios
  .filter((item) => entry.data.related_scenarios.includes(item.data.id))
  .map((item) => ({ label: item.data.title, href: `/scenarios/${entrySlug(item.id)}` }));

const relatedConceptLinks = allConcepts
  .filter((item) => entry.data.related_concepts.includes(item.data.id))
  .map((item) => ({ label: item.data.title, href: `/concepts/${entrySlug(item.id)}` }));

const currentSlug = entrySlug(entry.id);
const diagramCode = extractFirstMermaidBlock(entry.body);

const sections = [
  { id: 'what-it-is', label: 'What it is' },
  { id: 'why', label: 'Why it exists' },
  { id: 'when-to-use', label: 'When to use' },
  { id: 'when-not', label: 'When not to use' },
  { id: 'tradeoffs', label: 'Tradeoffs' },
  { id: 'examples', label: 'Examples' },
  { id: 'mistakes', label: 'Common mistakes' }
];
---

<MainLayout title={`${entry.data.title} | Pattern Atlas`} description={entry.data.summary}>
  <TrackView id={entry.data.id} type="pattern" title={entry.data.title} slug={currentSlug} />

  <ContentPageLayout sectionTitle="Pattern detail">
    <SectionNav slot="left" items={sections} />

    <header>
      <h1 style="margin:0">{entry.data.title}</h1>
      <p class="muted">{entry.data.summary}</p>
      <div style="display:flex; gap:0.4rem; flex-wrap:wrap;">
        <span class="badge">{entry.data.category}</span>
        <span class="badge">{entry.data.level}</span>
        <span class="badge">{entry.data.estimated_read_time} min read</span>
        <span class="badge">{relatedScenarioLinks.length} related scenarios</span>
      </div>
    </header>

    <section id="what-it-is" class="section">
      <h2>What it is</h2>
      <p set:html={linkifyConcepts(entry.data.problem, relatedConceptLinks)} />
    </section>

    <section id="why" class="section">
      <h2>Why it exists</h2>
      <p set:html={linkifyConcepts(entry.data.why_it_exists, relatedConceptLinks)} />
      {diagramCode ? <DiagramBlock title="Simple diagram" code={diagramCode} /> : null}
    </section>

    <section id="when-to-use" class="section">
      <h2>When to use it</h2>
      <ul>{entry.data.when_to_use.map((item) => <li set:html={linkifyConcepts(item, relatedConceptLinks)} />)}</ul>
    </section>

    <section id="when-not" class="section">
      <h2>When not to use it</h2>
      <ul>{entry.data.when_not_to_use.map((item) => <li set:html={linkifyConcepts(item, relatedConceptLinks)} />)}</ul>
    </section>

    <section id="tradeoffs" class="section">
      <h2>Tradeoffs</h2>
      <ul>{entry.data.tradeoffs.map((item) => <li set:html={linkifyConcepts(item, relatedConceptLinks)} />)}</ul>
    </section>

    <section id="examples" class="section">
      <h2>Example systems</h2>
      <ul>{entry.data.examples.map((item) => <li set:html={linkifyConcepts(item, relatedConceptLinks)} />)}</ul>
    </section>

    <section id="mistakes" class="section">
      <h2>Common mistakes</h2>
      <ul>{entry.data.common_mistakes.map((item) => <li set:html={linkifyConcepts(item, relatedConceptLinks)} />)}</ul>
    </section>

    <section class="section card" style="box-shadow:none;">
      <h2 style="margin-top:0">Next actions</h2>
      <p><a href={`/quiz/${entry.data.quiz_ids[0] === 'quiz_pattern_fundamentals' ? 'pattern-fundamentals' : 'tradeoff-judgment'}`}>Take related quiz</a></p>
      <p style="margin-bottom:0"><a href={relatedConceptLinks[0]?.href ?? '/concepts'}>Next recommended concept</a></p>
    </section>

    <div slot="right" style="display:grid; gap:1rem;">
      <QuickSummary
        bestFor={entry.data.best_for}
        avoidWhen={entry.data.avoid_when}
        mainTradeoff={entry.data.main_tradeoff}
      />
      <RelatedLinks title="Related concepts" links={relatedConceptLinks} />
      <RelatedLinks title="Related patterns" links={relatedPatternLinks} />
      <RelatedLinks title="Related scenarios" links={relatedScenarioLinks} />
    </div>
  </ContentPageLayout>
</MainLayout>
