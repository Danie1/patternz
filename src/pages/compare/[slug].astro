---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import TrackView from '@/components/TrackView.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import { entrySlug } from '@/lib/content';

export async function getStaticPaths() {
  const comparisons = await getCollection('comparisons');
  return comparisons.map((entry) => ({
    params: { slug: entrySlug(entry.id) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const patterns = await getCollection('patterns');
const scenarios = await getCollection('scenarios');

const relatedPatternLinks = patterns
  .filter((item) => entry.data.related_patterns.includes(item.data.id))
  .map((item) => ({ label: item.data.title, href: `/patterns/${entrySlug(item.id)}` }));
const relatedScenarioLinks = scenarios
  .filter((item) => entry.data.related_scenarios.includes(item.data.id))
  .map((item) => ({ label: item.data.title, href: `/scenarios/${entrySlug(item.id)}` }));

const currentSlug = entrySlug(entry.id);
---

<MainLayout title={`${entry.data.title} | Compare`} description={entry.data.summary}>
  <TrackView id={entry.data.id} type="comparison" title={entry.data.title} slug={currentSlug} />

  <section class="card section">
    <p class="kicker">Comparison</p>
    <h1 style="margin-top:0">{entry.data.title}</h1>
    <p class="muted">{entry.data.summary}</p>
    <div style="display:flex; gap:0.4rem; flex-wrap:wrap; margin-bottom:1rem;">
      {entry.data.compared_options.map((option) => <span class="badge">{option}</span>)}
    </div>

    <table class="matrix">
      <thead>
        <tr>
          <th>Dimension</th>
          {entry.data.compared_options.map((option) => <th>{option}</th>)}
        </tr>
      </thead>
      <tbody>
        {entry.data.dimensions.map((dimension) => (
          <tr>
            <td>{dimension.name}</td>
            {entry.data.compared_options.map((option) => <td>{dimension.option_scores[option]}</td>)}
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="grid-cards section">
    <article class="card">
      <h2 style="margin-top:0">Choose when</h2>
      <ul>{entry.data.recommended_when.map((item) => <li>{item}</li>)}</ul>
    </article>
    <article class="card">
      <h2 style="margin-top:0">Avoid when</h2>
      <ul>{entry.data.anti_patterns.map((item) => <li>{item}</li>)}</ul>
    </article>
  </section>

  <section class="grid-cards section">
    <article class="card">
      <RelatedLinks title="Related patterns" links={relatedPatternLinks} />
    </article>
    <article class="card">
      <RelatedLinks title="Related scenarios" links={relatedScenarioLinks} />
    </article>
  </section>
</MainLayout>
