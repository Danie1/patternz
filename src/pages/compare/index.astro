---
import MainLayout from '@/layouts/MainLayout.astro';
import LibraryLayout from '@/layouts/LibraryLayout.astro';
import ComparisonCard from '@/components/ComparisonCard.astro';
import { getComparisons } from '@/lib/content';

const comparisons = await getComparisons();
---

<MainLayout title="Compare Tradeoffs | Pattern Atlas" description="Structured architecture comparisons for judgment-oriented learning.">
  <LibraryLayout
    title="Tradeoff comparisons"
    description="Evaluate options across complexity, latency, consistency, cost, and maintainability dimensions."
  >
    <div class="grid-cards">
      {comparisons.map((comparison) => <ComparisonCard comparison={comparison} />)}
    </div>
  </LibraryLayout>
</MainLayout>
