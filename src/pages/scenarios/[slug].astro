---
import { getScenarios, entrySlug, roadmapTopicHref } from '@/lib/content';
import RouteRedirect from '@/components/RouteRedirect.astro';

export async function getStaticPaths() {
  const scenarios = await getScenarios();
  return scenarios.map((entry) => ({
    params: { slug: entrySlug(entry.id) },
    props: {
      title: entry.data.title,
      target: roadmapTopicHref(entrySlug(entry.id))
    }
  }));
}

const { title, target } = Astro.props;
---

<RouteRedirect
  title={`${title} | PatternZ`}
  target={target}
  message="Scenario details now open in the roadmap workspace side panel."
/>