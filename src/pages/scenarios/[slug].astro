---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import ContentPageLayout from '@/layouts/ContentPageLayout.astro';
import SectionNav from '@/components/SectionNav.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import DiagramBlock from '@/components/DiagramBlock.astro';
import VariantToggle from '@/components/islands/VariantToggle';
import SaveScenarioButton from '@/components/islands/SaveScenarioButton';
import TrackView from '@/components/TrackView.astro';
import { entrySlug, extractFirstMermaidBlock, linkifyConcepts } from '@/lib/content';

export async function getStaticPaths() {
  const scenarios = await getCollection('scenarios');
  return scenarios.map((entry) => ({
    params: { slug: entrySlug(entry.id) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const allPatterns = await getCollection('patterns');
const allComparisons = await getCollection('comparisons');
const allConcepts = await getCollection('concepts');

const relatedPatternLinks = allPatterns
  .filter((item) => entry.data.related_patterns.includes(item.data.id))
  .map((item) => ({ label: item.data.title, href: `/patterns/${entrySlug(item.id)}` }));

const relatedComparisonLinks = allComparisons
  .filter((item) => entry.data.related_comparisons.includes(item.data.id))
  .map((item) => ({ label: item.data.title, href: `/compare/${entrySlug(item.id)}` }));

const relatedConceptLinks = allConcepts
  .filter((item) => entry.data.concept_links.includes(item.data.id))
  .map((item) => ({ label: item.data.title, href: `/concepts/${entrySlug(item.id)}` }));

const currentSlug = entrySlug(entry.id);
const diagramCode = extractFirstMermaidBlock(entry.body);

const sections = [
  { id: 'intro', label: 'Scenario intro' },
  { id: 'requirements', label: 'Requirements' },
  { id: 'baseline', label: 'Baseline design' },
  { id: 'steps', label: 'Design decisions' },
  { id: 'concepts', label: 'Key concepts' },
  { id: 'changes', label: 'What changes' }
];
---

<MainLayout title={`${entry.data.title} | Scenario`} description={entry.data.summary}>
  <TrackView id={entry.data.id} type="scenario" title={entry.data.title} slug={currentSlug} />

  <ContentPageLayout sectionTitle="Scenario explorer">
    <SectionNav slot="left" items={sections} />

    <section id="intro" class="section">
      <h1 style="margin:0">{entry.data.title}</h1>
      <p class="muted">{entry.data.summary}</p>
      <div style="display:flex; gap:0.4rem; flex-wrap:wrap;">
        <span class="badge">{entry.data.level}</span>
        <span class="badge">{entry.data.system_type}</span>
        <span class="badge">{entry.data.estimated_time} min scenario</span>
      </div>
      <div style="margin-top:0.7rem;">
        <SaveScenarioButton client:idle id={entry.data.id} title={entry.data.title} slug={currentSlug} />
      </div>
    </section>

    <section id="requirements" class="section">
      <h2>Requirements</h2>
      <h3>Functional</h3>
      <ul>{entry.data.functional_requirements.map((item) => <li set:html={linkifyConcepts(item, relatedConceptLinks)} />)}</ul>
      <h3>Non-functional</h3>
      <ul>{entry.data.non_functional_requirements.map((item) => <li set:html={linkifyConcepts(item, relatedConceptLinks)} />)}</ul>
    </section>

    <section id="baseline" class="section">
      <h2>Baseline design</h2>
      <p set:html={linkifyConcepts(entry.data.initial_design, relatedConceptLinks)} />
      {diagramCode ? <DiagramBlock title="Architecture diagram" code={diagramCode} /> : null}
    </section>

    <section id="steps" class="section">
      <h2>Design decisions step by step</h2>
      <ol>{entry.data.design_steps.map((step) => <li set:html={linkifyConcepts(step, relatedConceptLinks)} />)}</ol>
    </section>

    <section id="concepts" class="section">
      <h2>Key concepts used</h2>
      <div style="display:flex; gap:0.4rem; flex-wrap:wrap;">
        {relatedConceptLinks.map((link) => <a class="badge" href={link.href}>{link.label}</a>)}
      </div>
    </section>

    <section id="changes" class="section">
      <h2>What changes if scale, cost, or latency shifts</h2>
      <VariantToggle client:visible variants={entry.data.architecture_variants} />
    </section>

    <section class="section card" style="box-shadow:none;">
      <h2 style="margin-top:0">Quiz and compare next</h2>
      <p><a href={`/quiz/${entry.data.quiz_ids[0] === 'quiz_scenario_steps' ? 'scenario-design-steps' : 'tradeoff-judgment'}`}>Run scenario self-check quiz</a></p>
      <p style="margin-bottom:0"><a href={relatedComparisonLinks[0]?.href ?? '/compare'}>Open related comparison</a></p>
    </section>

    <div slot="right" style="display:grid; gap:1rem;">
      <RelatedLinks title="Related concepts" links={relatedConceptLinks} />
      <RelatedLinks title="Related patterns" links={relatedPatternLinks} />
      <RelatedLinks title="Related comparisons" links={relatedComparisonLinks} />
    </div>
  </ContentPageLayout>
</MainLayout>
