---
import MainLayout from '@/layouts/MainLayout.astro';
import LibraryLayout from '@/layouts/LibraryLayout.astro';
import ScenarioCard from '@/components/ScenarioCard.astro';
import { getScenarios } from '@/lib/content';

const scenarios = await getScenarios();
---

<MainLayout title="Scenarios | Pattern Atlas" description="Guided architecture scenario explorations for practical system design intuition.">
  <LibraryLayout
    title="Scenario explorer"
    description="Understand how multiple patterns combine under real constraints."
  >
    <div class="grid-cards">
      {scenarios.map((scenario) => <ScenarioCard scenario={scenario} />)}
    </div>
  </LibraryLayout>
</MainLayout>
