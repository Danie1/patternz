---
import MainLayout from '@/layouts/MainLayout.astro';
import LibraryLayout from '@/layouts/LibraryLayout.astro';
import ConceptCard from '@/components/ConceptCard.astro';
import { getConcepts } from '@/lib/content';

const concepts = await getConcepts();
---

<MainLayout title="Concepts | Pattern Atlas" description="Foundational architecture concepts that explain system guarantees and tradeoffs.">
  <LibraryLayout
    title="Concept library"
    description="Learn core architecture properties first, then apply them through concrete patterns."
  >
    <div class="grid-cards">
      {concepts.map((concept) => <ConceptCard concept={concept} />)}
    </div>
  </LibraryLayout>
</MainLayout>