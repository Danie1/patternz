---
import MainLayout from '@/layouts/MainLayout.astro';
import RoadmapWorkspace from '@/components/islands/RoadmapWorkspace';
import { getRoadmapGraph } from '@/lib/content';

const graph = await getRoadmapGraph();
---


<MainLayout title="PatternZ | Interactive Knowledge Map" description="Explore software architecture concepts, patterns, and scenarios through an interactive roadmap workspace." mainClass="container container-left roadmap-home-main">
	<RoadmapWorkspace graph={graph} client:load />
</MainLayout>
