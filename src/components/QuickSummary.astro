---
interface Props {
  bestFor: string;
  avoidWhen: string;
  mainTradeoff: string;
}

const { bestFor, avoidWhen, mainTradeoff } = Astro.props;
---

<section>
  <h3 style="margin-top:0">Quick summary</h3>
  <dl style="margin:0; display:grid; gap:0.75rem;">
    <div>
      <dt class="kicker">Best for</dt>
      <dd style="margin:0">{bestFor}</dd>
    </div>
    <div>
      <dt class="kicker">Avoid when</dt>
      <dd style="margin:0">{avoidWhen}</dd>
    </div>
    <div>
      <dt class="kicker">Main tradeoff</dt>
      <dd style="margin:0">{mainTradeoff}</dd>
    </div>
  </dl>
</section>
