---
interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  title?: string;
  links: LinkItem[];
}

const { title = 'Related concepts', links } = Astro.props;
---

<section>
  <h3 style="margin-top:0">{title}</h3>
  <ul style="padding-left:1rem; margin:0; display:grid; gap:0.5rem;">
    {links.map((link) => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</section>
