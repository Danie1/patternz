---
import '@/styles/global.css';
import { siteConfig } from '@/lib/site';
import SearchModal from '@/components/islands/SearchModal';

interface Props {
  title: string;
  description?: string;
  mainClass?: string;
}

const { title, description = siteConfig.description, mainClass = 'container' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <slot name="head" />
  </head>
  <body>
    <div class="shell">
      <header class="top-nav">
        <div class="container top-nav-inner">
          <a href="/" style="font-weight:700; color:var(--text)">{siteConfig.name}</a>
          <nav class="nav-links" aria-label="Primary">
            {siteConfig.nav.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>
          <div style="display:flex; gap:0.6rem; align-items:center">
            <SearchModal client:idle />
          </div>
        </div>
      </header>

      <main class={mainClass} style="padding-block:1.2rem 2rem">
        <slot />
      </main>

      <footer class="container footer">
        <div style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
          <span>{siteConfig.name} is a content-first architecture handbook.</span>
          <span>
            <a href="/about">Method</a> · <a href="/progress">Progress</a> · <a href="/search">Search</a>
          </span>
        </div>
      </footer>
    </div>
  </body>
</html>
